# NoWorry Home - Environment Variables
# Copy this to .env.local and fill in your values.

# ── Client (Vite) — bundled into the browser build ───────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Server (Vercel serverless functions: api/cron/*) ─────────────────────────
# These are NEVER prefixed with VITE_ — that would expose them to the client.
# SUPABASE_URL is the same value as VITE_SUPABASE_URL above, but the server
# runtime can't read VITE_ vars, so it needs its own copy.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend (trial drip emails). Use onboarding@resend.dev until your sending
# domain is verified, then switch to e.g. hello@noworry-home.com.
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=onboarding@resend.dev

# Vercel Cron auth. Generate a long random string (e.g. `openssl rand -hex 32`)
# and set the SAME value in Vercel project settings → Environment Variables.
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` on every invocation;
# the function rejects any request whose header doesn't match.
CRON_SECRET=generate-a-long-random-string

# ── Stripe (subscription billing) ────────────────────────────────────────────
# Client-side publishable key — safe to bundle. Use the test key (pk_test_…)
# in development; swap to live key when going to production.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Server-side secret key — NEVER bundle this. Used by api/stripe/* routes
# to create customers, subscriptions, and cancellations.
STRIPE_SECRET_KEY=sk_test_replace_me

# Recurring price ID for the Prepared subscription. Create in Stripe
# Dashboard → Products as a recurring monthly price at $12, then paste the
# price_… ID here. Required by api/stripe/create-subscription.mjs.
STRIPE_PRICE_PREPARED=price_replace_me

# Webhook signing secret. Stripe Dashboard → Developers → Webhooks →
# the endpoint you create pointing at /api/stripe/webhook. The webhook
# route is stubbed today (returns 501) — Phase 3 will implement
# customer.subscription.deleted, invoice.payment_failed, invoice.paid.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
